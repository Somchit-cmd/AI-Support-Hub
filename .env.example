# =============================================================================
# AI Support Hub - Environment Variables
# =============================================================================
# Copy this file to ".env" and adjust as needed:
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows cmd)
#
# Only DATABASE_URL is required to run the app. Channel credentials and AI
# provider API keys are configured at runtime through the in-app Settings UI
# and stored in the database (Setting table) - NOT in environment variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# -----------------------------------------------------------------------------
# SQLite database file. A relative path is recommended for portability.
# On first run, run: npx prisma db push   (creates the file + tables)
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Node environment
# -----------------------------------------------------------------------------
# Set to "production" for production builds.
NODE_ENV=development

# -----------------------------------------------------------------------------
# OPTIONAL: Automation inactivity sweep (cron)
# -----------------------------------------------------------------------------
# The inactivity automation trigger runs via a cron endpoint, NOT automatically.
# Set a secret token here, then schedule an external job (Vercel Cron,
# cron-job.org, GitHub Actions) to hit this URL hourly:
#
#   GET https://your-app.com/api/automation/run?token=YOUR_SECRET_HERE
#
# Until this is set, the inactivity sweep returns 503 and never runs.
# Generate a token, e.g.:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# AUTOMATION_CRON_TOKEN=replace-with-a-random-secret

# -----------------------------------------------------------------------------
# OPTIONAL: Real-time chat service
# -----------------------------------------------------------------------------
# The standalone Socket.IO service (mini-services/chat-service) is not wired
# into the app today; real-time delivery uses Server-Sent Events instead.
# Listed here for future configuration.
# CHAT_SERVICE_PORT=3003
